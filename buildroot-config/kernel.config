# x86_64, serial console, initramfs support
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# Basic kernel features
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_ELF_CORE=y

# Memory
CONFIG_FLATMEM=y
CONFIG_SPARSEMEM_MANUAL=y

# initramfs/initrd
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y

# TTY/Console
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_CONSOLE_TRANSLATIONS=y
CONFIG_VT_CONSOLE=y
CONFIG_HW_CONSOLE=y
CONFIG_UNIX98_PTYS=y

# Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Basic block devices
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y

# Filesystems
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# EROFS
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y
CONFIG_EROFS_FS_POSIX_ACL=y

# EFI/UKI support
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y

# Networking base
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# PCI
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# Virtio
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# Crypto
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y

# Modules disabled
CONFIG_MODULES=n
