# Architecture
BR2_x86_64=y
BR2_x86_Core2=y

# Toolchain glibc (required by systemd)
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

# System
BR2_TARGET_GENERIC_HOSTNAME="singularity"
BR2_TARGET_GENERIC_ISSUE="Singularity OS"
BR2_ROOTFS_MERGED_USR=y
BR2_TARGET_GENERIC_ROOT_PASSWD=""

# Init - systemd
BR2_INIT_SYSTEMD=y

# systemd
BR2_PACKAGE_SYSTEMD=y
BR2_PACKAGE_DBUS=y
BR2_PACKAGE_LINUX_PAM=y
BR2_PACKAGE_KMOD=y
BR2_PACKAGE_KMOD_TOOLS=y
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_UTIL_LINUX_MOUNT=y
BR2_PACKAGE_SYSTEMD_NETWORKD=y
BR2_PACKAGE_SYSTEMD_RESOLVED=y
BR2_PACKAGE_SYSTEMD_LOGIND=y
BR2_PACKAGE_SYSTEMD_BOOTCTL=y

# Base utilities
BR2_PACKAGE_BUSYBOX=y

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_VERSION=y
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_SINGULARITY_PATH)/buildroot-config/kernel.config"
BR2_LINUX_KERNEL_NEEDS_HOST_LIBELF=y

# Graphics: software EGL/GL via mesa3d llvmpipe (HW drivers added later)
BR2_PACKAGE_MESA3D=y
BR2_PACKAGE_MESA3D_LLVM=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_LLVMPIPE=y
BR2_PACKAGE_MESA3D_GBM=y
BR2_PACKAGE_MESA3D_OPENGL_EGL=y
BR2_PACKAGE_MESA3D_OPENGL_ES=y

# GTK4 (Wayland)
BR2_PACKAGE_LIBGTK4=y
BR2_PACKAGE_LIBGTK4_WAYLAND=y
BR2_PACKAGE_GTK4_LAYER_SHELL=y

# Desktop libraries (GTK4 stack)
BR2_PACKAGE_GRAPHENE=y
BR2_PACKAGE_GTKSOURCEVIEW=y
BR2_PACKAGE_LIBSECRET=y
BR2_PACKAGE_LIBSOUP3=y
BR2_PACKAGE_JSON_GLIB=y
BR2_PACKAGE_LIBGEE=y
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_GOBJECT_INTROSPECTION=y
BR2_PACKAGE_LIBPEAS2=y
BR2_PACKAGE_VTE_GTK4=y
BR2_PACKAGE_LIBSINGULARITY=y
BR2_PACKAGE_SINGULARITY_LOGINUI=y
BR2_PACKAGE_SINGULARITY_BOOT_SPLASH=y
BR2_PACKAGE_LABWC=y
BR2_PACKAGE_WEBKITGTK=y
BR2_PACKAGE_GSTREAMER1=y
BR2_PACKAGE_SINGULARITY_SESSION=y

# Fonts
BR2_PACKAGE_DEJAVU=y

# Rootfs integration (greetd login, full desktop session, greeter user)
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_SINGULARITY_PATH)/rootfs-overlay"
BR2_ROOTFS_USERS_TABLES="$(BR2_EXTERNAL_SINGULARITY_PATH)/board/users.txt"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_SINGULARITY_PATH)/scripts/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_SINGULARITY_PATH)/scripts/post-image.sh"

# Filesystem
BR2_TARGET_ROOTFS_TAR=y
BR2_TARGET_ROOTFS_TAR_BZIP2=y
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_TARGET_ROOTFS_EROFS=y
BR2_TARGET_ROOTFS_EROFS_LZ4HC=y
BR2_TARGET_ROOTFS_EROFS_LZ4HC_LEVEL=12
BR2_TARGET_ROOTFS_EROFS_ZTAILPACKING=y
BR2_PACKAGE_HOST_DOSFSTOOLS=y
BR2_PACKAGE_HOST_MTOOLS=y
BR2_PACKAGE_XKEYBOARD_CONFIG=y
BR2_PACKAGE_SEATD_DAEMON=y
BR2_PACKAGE_SEATD_BUILTIN=y
BR2_PACKAGE_PIPEWIRE=y
