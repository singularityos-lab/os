config BR2_PACKAGE_SINGULARITY_SESSION
	bool "singularity-session (full desktop)"
	depends on BR2_PACKAGE_LIBGTK4
	depends on BR2_PACKAGE_GOBJECT_INTROSPECTION
	depends on BR2_PACKAGE_WEBKITGTK || BR2_PACKAGE_WEBKITGTK_PREBUILT
	depends on BR2_PACKAGE_GSTREAMER1
	select BR2_PACKAGE_LABWC
	select BR2_PACKAGE_SINGULARITY_SHELL
	select BR2_PACKAGE_SINGULARITY_DESKTOP_DATA
	select BR2_PACKAGE_SINGULARITY_THEMES
	select BR2_PACKAGE_SINGULARITY_WALLPAPERS
	select BR2_PACKAGE_SINGULARITY_WIDGETS
	select BR2_PACKAGE_SINGULARITY_PLUGINS
	select BR2_PACKAGE_SINGULARITY_POLKIT_AGENT
	select BR2_PACKAGE_XDG_DESKTOP_PORTAL_SINGULARITY
	select BR2_PACKAGE_SINGULARITY_SPLASH
	select BR2_PACKAGE_SINGULARITY_GREETER
	select BR2_PACKAGE_SINGULARITY_KEYRING
	select BR2_PACKAGE_SINGULARITY_FILES
	select BR2_PACKAGE_SINGULARITY_EDIT
	select BR2_PACKAGE_SINGULARITY_WRITE
	select BR2_PACKAGE_SINGULARITY_STORE
	select BR2_PACKAGE_SINGULARITY_MONITOR
	select BR2_PACKAGE_SINGULARITY_GIT
	select BR2_PACKAGE_SINGULARITY_MUSIC
	select BR2_PACKAGE_SINGULARITY_PHOTOS
	select BR2_PACKAGE_SINGULARITY_VIDEOS
	select BR2_PACKAGE_SINGULARITY_CALENDAR
	select BR2_PACKAGE_SINGULARITY_CALCULATOR
	select BR2_PACKAGE_SINGULARITY_LEAFS
	help
	  The Singularity session: labwc session launcher and config plus
	  the full Singularity desktop (shell, greeter, keyring and all
	  first-party apps).

	  https://github.com/singularityos-lab/singularity-session
