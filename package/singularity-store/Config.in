config BR2_PACKAGE_SINGULARITY_STORE
	bool "singularity-store"
	depends on BR2_PACKAGE_LIBGTK4
	select BR2_PACKAGE_LIBSINGULARITY
	select BR2_PACKAGE_LIBGEE
	select BR2_PACKAGE_LIBSOUP3
	select BR2_PACKAGE_JSON_GLIB
	help
	  Singularity Store: the application store.

	  https://github.com/singularityos-lab/singularity-store
