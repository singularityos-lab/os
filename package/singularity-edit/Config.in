config BR2_PACKAGE_SINGULARITY_EDIT
	bool "singularity-edit"
	depends on BR2_PACKAGE_LIBGTK4
	depends on BR2_PACKAGE_WEBKITGTK || BR2_PACKAGE_WEBKITGTK_PREBUILT
	select BR2_PACKAGE_LIBSINGULARITY
	select BR2_PACKAGE_LIBGEE
	select BR2_PACKAGE_GTKSOURCEVIEW
	help
	  Singularity Edit: the code editor.

	  https://github.com/singularityos-lab/singularity-edit
